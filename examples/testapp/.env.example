# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Service versions ──────────────────────────────────────────────────────────
# Used as the image tag for locally-built images.
# Bump to trigger a dpivot zero-downtime rollout.
FRONTEND_VERSION=1.0.0
API_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank to run Redis without authentication.
REDIS_PASSWORD=
